{
  "name": "resume-generator",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Resume Generator App",
  "author": "Nikesh Chavhan",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rimraf dist dist-electron release",
    "build": "tsc -b && vite build",
    "build:exe": "npm run clean && npm run build && electron-builder",
    "mcp": "tsx src/mcp-server.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.7.0",
    "nunjucks": "^3.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.resume.generator",
    "productName": "ResumeGenerator",
    "publish": {
      "provider": "github",
      "owner": "vicky-dx",
      "repo": "resume-generator"
    },
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "../templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "public/resume-icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
